# Base URL of the RBMS backend API (no trailing slash).
NEXT_PUBLIC_API_BASE_URL=http://localhost:5080

# Display name shown in the app shell.
NEXT_PUBLIC_APP_NAME=RBMS

# Default store for the single-store phase (the seeded store).
NEXT_PUBLIC_DEFAULT_STORE_ID=aaaaaaaa-0000-0000-0000-000000000002

# Currency used for money formatting.
NEXT_PUBLIC_CURRENCY=INR

# Optional: request timeout in milliseconds for the axios client.
NEXT_PUBLIC_API_TIMEOUT_MS=15000
