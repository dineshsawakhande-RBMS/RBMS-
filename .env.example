# Copy to .env for `docker compose up`.

# --- Database ---
POSTGRES_DB=rbms
POSTGRES_USER=rbms_admin
POSTGRES_PASSWORD=changeme_local

# --- API / JWT ---
JWT_ISSUER=rbms-api
JWT_AUDIENCE=rbms-api
# Must be at least 32 characters for HMAC-SHA256 signing.
JWT_SIGNING_KEY=local_dev_signing_key_change_me_please_32+chars

# --- Web ---
# URL the browser uses to reach the API (inlined at build time).
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
